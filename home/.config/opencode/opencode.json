{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3"
  ],
  "small_model": "opencode/big-pickle",
  "agent": {
    "explore": {
      "temperature": 0.1,
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "options": {},
      "permission": {}
    },
    "general": {
      "temperature": 0.2,
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "options": {},
      "permission": {}
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}
