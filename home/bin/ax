#!/usr/bin/env bash
set -euo pipefail

FRPC_BIN="${AX_FRPC_BIN:-$(command -v frpc 2>/dev/null || true)}"
SERVER_PORT="${AX_FRPS_PORT:-${FRP_PORT:-7500}}"
TOKEN="${AX_TOKEN:-${AP_HOST_TOKEN:-agentpod}}"
LISTEN_TIMEOUT="${AX_LISTEN_TIMEOUT:-30}"
HTTP_PORT="${AX_HTTP_PORT:-8080}"

detect_server_addr() {
  local candidate

  for candidate in host.docker.internal localhost; do
    if host_resolves "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf '%s\n' localhost
}

host_resolves() {
  local host="$1"

  if command -v getent >/dev/null 2>&1; then
    getent ahosts "$host" >/dev/null 2>&1 && return 0
  fi

  if command -v dscacheutil >/dev/null 2>&1; then
    dscacheutil -q host -a name "$host" >/dev/null 2>&1 && return 0
  fi

  return 1
}

SERVER_ADDR="${AX_FRPS_ADDR:-$(detect_server_addr)}"

# Build domain list with precedence: AX_DOMAINS > FRP_DOMAINS > AX_DOMAIN > localhost
DOMAINS=""
if [[ -n "${AX_DOMAINS:-}" ]]; then
  DOMAINS="$AX_DOMAINS"
elif [[ -n "${FRP_DOMAINS:-}" ]]; then
  DOMAINS="$FRP_DOMAINS"
elif [[ -n "${AX_DOMAIN:-}" ]]; then
  DOMAINS="$AX_DOMAIN"
else
  DOMAINS="localhost"
fi

# Parse comma-separated domains into array, trim spaces, filter empty
DOMAIN_LIST=()
while IFS=',' read -ra _parts; do
  for _d in "${_parts[@]}"; do
    _trimmed="${_d#"${_d%%[![:space:]]*}"}"
    _trimmed="${_trimmed%"${_trimmed##*[![:space:]]}"}"
    [[ -n "$_trimmed" ]] && DOMAIN_LIST+=("$_trimmed")
  done
done <<< "$DOMAINS"

# Fallback if no valid domains found
if [[ ${#DOMAIN_LIST[@]} -eq 0 ]]; then
  DOMAIN_LIST+=("localhost")
fi

NAME=""

usage() {
  cat <<'EOF'
Usage:
  ax <port>
  ax [--name NAME] <port>
  ax [--name NAME] <port> <command...>

Examples:
  ax 5432
  ax 4096 opencode
  ax --name api 3000 npm run dev

Environment:
  AX_FRPC_BIN        frpc binary path (default: frpc from PATH)
  AX_FRPS_ADDR       frps address (default: auto-detect host.docker.internal, then localhost)
  FRP_PORT           shared frps/frpc control port override (default: 7500)
  AX_FRPS_PORT       frps port (default: FRP_PORT or 7500)
  AX_DOMAINS         comma-separated route domain suffixes (e.g., "localhost,100.115.158.97.sslip.io")
  FRP_DOMAINS        shared fallback for domain suffixes
  AX_DOMAIN          legacy single domain suffix (default: localhost)
  AX_HTTP_PORT       HTTP port for route URLs (default: 8080)
  AX_TOKEN           frps auth token (default: agentpod)
  AX_LISTEN_TIMEOUT  seconds to wait for child port bind (default: 30)

Domain precedence: AX_DOMAINS > FRP_DOMAINS > AX_DOMAIN > localhost

Each ax invocation owns exactly one frpc process for one port.
Runs in foreground until Ctrl-C or child command exits.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)
      shift
      [[ $# -gt 0 ]] || { printf '%s\n' '--name requires a value' >&2; exit 1; }
      NAME="$1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'Unknown flag: %s\n' "$1" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

[[ $# -ge 1 ]] || { usage >&2; exit 1; }
PORT="$1"
shift

[[ "$PORT" =~ ^[0-9]+$ ]] || { printf 'Port must be numeric: %s\n' "$PORT" >&2; exit 1; }

if [[ -z "$NAME" ]]; then
  if GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    NAME="$(basename "$GIT_ROOT")"
  else
    NAME="$(basename "$PWD")"
  fi
fi

# Build hostname list from all domains
HOSTNAMES=()
for _domain in "${DOMAIN_LIST[@]}"; do
  HOSTNAMES+=("${PORT}-${NAME}.${_domain}")
done

# Build URL list for display
URLS=()
for _host in "${HOSTNAMES[@]}"; do
  URLS+=("http://${_host}:${HTTP_PORT}")
done
CONFIG_FILE=""
FRPC_PID=""
CHILD_PID=""

if [[ -z "$FRPC_BIN" || ! -x "$FRPC_BIN" ]]; then
  printf 'frpc not found. Install it first and/or set AX_FRPC_BIN.\n' >&2
  exit 1
fi

is_port_listening() {
  local port="$1"

  if command -v lsof >/dev/null 2>&1; then
    lsof -n -P -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1 && return 0
  fi

  if command -v ss >/dev/null 2>&1; then
    ss -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "(^|:)$port$" && return 0
  fi

  if command -v netstat >/dev/null 2>&1; then
    netstat -lnt 2>/dev/null | awk '{print $4}' | grep -Eq "(^|:)$port$" && return 0
  fi

  return 1
}

wait_for_port() {
  local port="$1" elapsed=0
  while [[ "$elapsed" -lt "$LISTEN_TIMEOUT" ]]; do
    if is_port_listening "$port"; then
      return 0
    fi
    if [[ -n "$CHILD_PID" ]] && ! kill -0 "$CHILD_PID" >/dev/null 2>&1; then
      return 1
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  return 1
}

cleanup() {
  local exit_code="$?"
  trap - EXIT INT TERM

  if [[ -n "$CHILD_PID" ]]; then
    kill "$CHILD_PID" >/dev/null 2>&1 || true
    wait "$CHILD_PID" 2>/dev/null || true
  fi

  if [[ -n "$FRPC_PID" ]]; then
    kill "$FRPC_PID" >/dev/null 2>&1 || true
    wait "$FRPC_PID" 2>/dev/null || true
  fi

  if [[ -n "$CONFIG_FILE" && -f "$CONFIG_FILE" ]]; then
    rm -f "$CONFIG_FILE"
  fi

  exit "$exit_code"
}

trap cleanup EXIT INT TERM

CONFIG_FILE="$(mktemp "${TMPDIR:-/tmp}/ax-frpc.XXXXXX")"

# Build customDomains array for frpc config
CUSTOM_DOMAINS=""
for _host in "${HOSTNAMES[@]}"; do
  if [[ -n "$CUSTOM_DOMAINS" ]]; then
    CUSTOM_DOMAINS="$CUSTOM_DOMAINS, \"$_host\""
  else
    CUSTOM_DOMAINS="\"$_host\""
  fi
done

cat > "$CONFIG_FILE" <<EOF
serverAddr = "$SERVER_ADDR"
serverPort = $SERVER_PORT
loginFailExit = true

[auth]
method = "token"
token = "$TOKEN"

[[proxies]]
name = "${PORT}-${NAME}"
type = "http"
localIP = "127.0.0.1"
localPort = $PORT
customDomains = [$CUSTOM_DOMAINS]
EOF

if [[ $# -eq 0 ]]; then
  if ! is_port_listening "$PORT"; then
    printf 'Nothing is listening on port %s\n' "$PORT" >&2
    exit 1
  fi

  printf 'Exposing:\n'
  for _url in "${URLS[@]}"; do
    printf '  %s\n' "$_url"
  done
  printf 'Press Ctrl-C to stop\n'

  "$FRPC_BIN" -c "$CONFIG_FILE" &
  FRPC_PID="$!"

  wait "$FRPC_PID"
else
  "$@" &
  CHILD_PID="$!"

  printf 'Waiting for port %s to listen (timeout: %ss)...\n' "$PORT" "$LISTEN_TIMEOUT"
  if ! wait_for_port "$PORT"; then
    printf 'Timed out waiting for port %s to listen\n' "$PORT" >&2
    exit 1
  fi

  printf 'Exposing:\n'
  for _url in "${URLS[@]}"; do
    printf '  %s\n' "$_url"
  done
  printf 'Press Ctrl-C to stop\n'

  "$FRPC_BIN" -c "$CONFIG_FILE" &
  FRPC_PID="$!"

  wait "$CHILD_PID"
fi
